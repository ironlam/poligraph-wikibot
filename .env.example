# Poligraph DB (read-only)
DATABASE_URL=postgresql://readonly_user:password@host:5432/poligraph

# Wikidata bot credentials (Special:BotPasswords)
# Format: Username@BotPasswordName for username, generated token for password
WIKIDATA_BOT_USERNAME=PoliGraphBot@PoliGraphBot
WIKIDATA_BOT_PASSWORD=your_generated_bot_password_token

# Options
DRY_RUN=true
WIKIDATA_INSTANCE=https://test.wikidata.org
